{
  "schemaVersion": "app.0.1",
  "id": "com.haas.project-manager",
  "name": "Project Manager",
  "description": "Project planning, time tracking, release planning, and Azure DevOps coordination for Hosty users.",
  "version": "0.5.2",
  "source": {
    "type": "git",
    "repository": "https://github.com/alex-de-haas/project-manager.git",
    "branch": "main"
  },
  "runtimeProfiles": [
    {
      "key": "docker",
      "type": "docker",
      "default": true
    },
    {
      "key": "dev",
      "type": "localCommand"
    }
  ],
  "defaultRuntime": "docker",
  "services": [
    {
      "key": "app",
      "runtimes": {
        "docker": {
          "type": "docker",
          "image": {
            "repository": "ghcr.io/alex-de-haas/project-manager",
            "tag": "latest",
            "pullPolicy": "ifNotPresent"
          },
          "ports": [
            {
              "key": "http",
              "containerPort": 3000,
              "protocol": "http",
              "public": true
            }
          ],
          "resources": {
            "cpus": 1,
            "memory": "1g"
          },
          "healthcheck": {
            "type": "exec",
            "command": "node -e \"fetch('http://127.0.0.1:3000/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\"",
            "intervalSeconds": 10,
            "timeoutSeconds": 2,
            "retries": 3,
            "gracePeriodSeconds": 10
          }
        },
        "dev": {
          "type": "localCommand",
          "workingDirectory": ".",
          "command": "npm run dev",
          "ports": [
            {
              "key": "http",
              "containerPort": 3000,
              "protocol": "http",
              "public": true
            }
          ]
        }
      }
    }
  ],
  "endpoints": [
    {
      "key": "http",
      "service": "app",
      "port": "http",
      "public": true
    }
  ],
  "ui": {
    "category": "Apps",
    "icon": "calendar-days",
    "entrypoint": {
      "endpoint": "http",
      "path": "/"
    },
    "navigation": [
      {
        "label": "Time Management",
        "path": "/"
      },
      {
        "label": "Planning",
        "path": "/release-planner"
      },
      {
        "label": "Calendar",
        "path": "/day-offs"
      },
      {
        "label": "Settings",
        "path": "/settings"
      }
    ]
  },
  "data": {
    "enabled": true,
    "targets": [
      {
        "runtime": "docker",
        "service": "app",
        "containerPath": "/app/data",
        "environment": "HOSTY_APP_DATA_DIR"
      },
      {
        "runtime": "dev",
        "environment": "HOSTY_APP_DATA_DIR"
      }
    ]
  },
  "telemetry": { "enabled": true, "sampleRatio": 0.1 },
  "capabilities": ["open", "update", "restart", "stop", "remove", "backup", "restore", "logs"]
}
