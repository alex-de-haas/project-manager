{
  "metadataFile": "../metadata.dev.json",
  "moduleCommand": "npm run dev",
  "workingDirectory": "..",
  "environment": {
    "PORT": "3100"
  },
  "target": {
    "id": "mdev_project_manager",
    "hostname": "project-manager.localhost",
    "portKey": "http",
    "localPort": 3100,
    "policy": "assignedUsersOnly",
    "identity": "required"
  },
  "users": [
    {
      "email": "admin@dev.com",
      "displayName": "Dev Admin",
      "role": "host.admin",
      "assigned": true
    }
  ],
  "directoryPolicy": {
    "includeEmail": true
  }
}
